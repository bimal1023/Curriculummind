# ── Azure AI Foundry ──────────────────────────────────────────
FOUNDRY_PROJECT_ENDPOINT=https://<resource>.services.ai.azure.com/api/projects/<project>
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o
AZURE_CLIENT_ID=                        # leave blank to use DefaultAzureCredential

# ── Azure AI Search ───────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<search-resource>.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=learning-resources

# ── App settings ──────────────────────────────────────────────
APP_ENV=development                     # development | staging | production
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ── Telemetry (Azure Monitor) ─────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=  # optional; enables distributed tracing

# ── Agent tuning ──────────────────────────────────────────────
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=60
MAX_CONCURRENT_AGENTS=5
